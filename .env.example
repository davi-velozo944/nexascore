# ============================================
# NexaScore - Variáveis de Ambiente (Frontend)
# ============================================
# Copie este arquivo para `.env` (local) ou configure na Vercel
# em Settings → Environment Variables.

# URL do projeto Supabase
VITE_SUPABASE_URL="https://SEU_PROJECT_REF.supabase.co"

# Chave pública (anon) do Supabase — usada pelo frontend.
# Mantenha as DUAS variáveis abaixo com o MESMO valor (anon/publishable key).
VITE_SUPABASE_ANON_KEY="SUA_ANON_KEY_AQUI"
VITE_SUPABASE_PUBLISHABLE_KEY="SUA_ANON_KEY_AQUI"

# ID do projeto Supabase (opcional)
VITE_SUPABASE_PROJECT_ID="SEU_PROJECT_REF"

# Chave do Google AI Studio (Gemini) — gere em https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY="SUA_GEMINI_API_KEY_AQUI"

# ============================================
# Secrets do Backend (Edge Functions)
# ============================================
# Estas variáveis NÃO devem ser configuradas na Vercel.
# Devem ser cadastradas no painel do Supabase em:
# Project Settings → Edge Functions → Secrets
#
# GEMINI_API_KEY=...           # Google Gemini (IA)
# RESEND_API_KEY=...           # Envio de e-mails (Resend)
# STRIPE_SECRET_KEY=...        # Pagamentos Stripe
# STRIPE_WEBHOOK_SECRET=...    # Validação webhooks Stripe
# SUPABASE_SERVICE_ROLE_KEY=...# Injetada automaticamente
# SUPABASE_URL=...             # Injetada automaticamente
# SUPABASE_ANON_KEY=...        # Injetada automaticamente
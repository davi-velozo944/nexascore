dist/
dist-ssr/
build/
out/
.vite/
*.tsbuildinfo

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment variables (NUNCA commitar chaves)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
!.env.example


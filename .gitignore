Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Testes / Coverage
coverage/
.nyc_output/
*.lcov

# Caches
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.turbo/
.swc/

# Deploy
.vercel/
.netlify/
.firebase/
.output/

